---
// ── Full menu data from Las Olivias ──────────────────────────
const WA_BASE = "https://wa.me/522282557773?text=";

function pedirLink(item: string) {
  return WA_BASE + encodeURIComponent(`Hola Las Olivias, quisiera pedir: ${item} 🌮`);
}

const antojitos = [
  { name: "Picada Chica",              desc: "De frijoles, salsa roja o verde",                                       price: 12  },
  { name: "Picada Grande Sencilla",    desc: "De frijoles, salsa roja o verde",                                       price: 42  },
  { name: "Picada Grande Preparada",   desc: "Con milanesa, pollo, papa o queso",                                     price: 50  },
  { name: "Empanada Chica",            desc: "Queso, pollo, papa o picadillo",                                        price: 12  },
  { name: "Empanada Gigante",          desc: "Queso, pollo, papa o picadillo",                                        price: 42  },
  { name: "Tostada",                   desc: null,                                                                     price: 20  },
  { name: "Dorado de Papa",            desc: null,                                                                     price: 12  },
  { name: "Tapaditas de Frijol",       desc: null,                                                                     price: 12  },
  { name: "Taco de Guisado",           desc: "Guiso del día en doble tortilla",                                       price: 25  },
];

const platillos = [
  { name: "Huevos al Gusto",           desc: "Jamón, longaniza, mexicana, rancheros, divorciados o omelet con frijoles", price: 60 },
  { name: "Molletes",                  desc: "Manchego o queso de hebra",                                              price: 66 },
  { name: "Chilaquiles",               desc: "Verdes o rojos con pollo o huevo",                                       price: 66 },
  { name: "Enfrijoladas",              desc: "Pollo, queso, papa o huevo",                                             price: 66 },
  { name: "Enmoladas",                 desc: "Pollo, queso, papa o huevo",                                             price: 66 },
  { name: "Enchiladas",                desc: "Verdes o rojas con pollo, papa, queso o huevo",                          price: 66 },
  { name: "Enchiladas Suizas",         desc: "Verdes o rojas con pollo, papa, queso o huevo",                          price: 87 },
  { name: "Milanesa",                  desc: "Con ensalada, frijoles y arroz",                                         price: 82 },
  { name: "Pechuga a la Plancha",      desc: "Con ensalada, frijoles y arroz",                                         price: 82 },
];

const especialidades = [
  { name: "Pozole Chico",              desc: null,                                                                     price: 72 },
  { name: "Pozole Grande",             desc: null,                                                                     price: 82 },
  { name: "Costilla de Cerdo",         desc: "Con arroz y frijoles",                                                  price: 82 },
  { name: "Pollo con Mole",            desc: null,                                                                     price: 77 },
];
---

<section id="menu" class="px-4 py-20 sm:px-6 sm:py-24">
  <div class="mx-auto max-w-5xl">

    <!-- Section header -->
    <div class="mb-12 flex flex-col items-center text-center">
      <span
        class="mb-3 inline-block rounded-full bg-clay-accent/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-clay-accent"
      >Nuestro Menú</span>
      <h2
        class="text-3xl font-black text-clay-text sm:text-4xl md:text-5xl"
        style="font-family: 'Nunito', sans-serif;"
      >
        <span class="clay-gradient-text">Hecho con amor,</span><br />servido con sabor
      </h2>
      <p class="mt-3 max-w-sm text-sm font-medium text-clay-muted">
        Toca cualquier platillo para pedirlo directo por WhatsApp 💬
      </p>
    </div>

    <!-- ─── ANTOJITOS ─────────────────────────── -->
    <div class="mb-10">
      <div class="mb-5 flex items-center gap-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-2xl bg-linear-to-br from-amber-400 to-orange-500 text-xl"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        >🫓</span>
        <h3
          class="text-2xl font-black text-clay-text"
          style="font-family: 'Nunito', sans-serif;"
        >Antojitos</h3>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {antojitos.map((item) => (
          <a
            href={pedirLink(item.name)}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between gap-3 rounded-4xl bg-white/65 px-5 py-4 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
            style="box-shadow: var(--shadow-clay-card);"
          >
            <div class="flex flex-col gap-0.5 min-w-0">
              <span
                class="text-sm font-extrabold text-clay-text group-hover:text-clay-accent transition-colors"
                style="font-family: 'Nunito', sans-serif;"
              >{item.name}</span>
              {item.desc && (
                <span class="text-xs font-medium text-clay-muted leading-snug">{item.desc}</span>
              )}
            </div>
            <span
              class="shrink-0 rounded-2xl bg-clay-accent/10 px-3 py-1.5 text-sm font-black text-clay-accent"
              style="font-family: 'Nunito', sans-serif;"
            >
              ${item.price}
            </span>
          </a>
        ))}
      </div>

      <!-- Extras note -->
      <div
        class="mt-4 flex items-start gap-3 rounded-3xl bg-amber-50/80 px-5 py-4"
        style="box-shadow: var(--shadow-clay-pressed);"
      >
        <span class="text-base" aria-hidden="true">ℹ️</span>
        <p class="text-xs font-medium text-clay-muted">
          <strong class="text-clay-text">Ingrediente extra:</strong> antojitos pequeños +$5 · antojitos gigantes +$10 ·
          <strong class="text-clay-text">Para llevar:</strong> +$6 por uso de desechable.
        </p>
      </div>
    </div>

    <!-- ─── PLATILLOS ─────────────────────────── -->
    <div class="mb-10">
      <div class="mb-5 flex items-center gap-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-2xl bg-linear-to-br from-violet-400 to-violet-600 text-xl"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        >🍳</span>
        <h3
          class="text-2xl font-black text-clay-text"
          style="font-family: 'Nunito', sans-serif;"
        >Platillos</h3>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {platillos.map((item) => (
          <a
            href={pedirLink(item.name)}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between gap-3 rounded-4xl bg-white/65 px-5 py-4 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
            style="box-shadow: var(--shadow-clay-card);"
          >
            <div class="flex flex-col gap-0.5 min-w-0">
              <span
                class="text-sm font-extrabold text-clay-text group-hover:text-clay-accent-alt transition-colors"
                style="font-family: 'Nunito', sans-serif;"
              >{item.name}</span>
              {item.desc && (
                <span class="text-xs font-medium text-clay-muted leading-snug">{item.desc}</span>
              )}
            </div>
            <span
              class="shrink-0 rounded-2xl bg-clay-accent-alt/10 px-3 py-1.5 text-sm font-black text-clay-accent-alt"
              style="font-family: 'Nunito', sans-serif;"
            >
              ${item.price}
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- ─── ESPECIALIDADES (Solo Sábado) ─────── -->
    <div>
      <div class="mb-5 flex flex-wrap items-center gap-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-2xl bg-linear-to-br from-pink-400 to-pink-600 text-xl"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        >🫕</span>
        <h3
          class="text-2xl font-black text-clay-text"
          style="font-family: 'Nunito', sans-serif;"
        >Especialidades</h3>
        <span
          class="inline-flex items-center gap-1 rounded-full bg-clay-tertiary/15 px-3 py-1 text-xs font-bold text-clay-tertiary"
        >
          📅 Solo Sábados
        </span>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {especialidades.map((item) => (
          <a
            href={pedirLink(item.name)}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between gap-3 rounded-4xl bg-white/65 px-5 py-4 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
            style="box-shadow: var(--shadow-clay-card);"
          >
            <div class="flex flex-col gap-0.5 min-w-0">
              <span
                class="text-sm font-extrabold text-clay-text group-hover:text-clay-accent transition-colors"
                style="font-family: 'Nunito', sans-serif;"
              >{item.name}</span>
              {item.desc && (
                <span class="text-xs font-medium text-clay-muted leading-snug">{item.desc}</span>
              )}
            </div>
            <span
              class="shrink-0 rounded-2xl bg-clay-tertiary/15 px-3 py-1.5 text-sm font-black text-clay-tertiary"
              style="font-family: 'Nunito', sans-serif;"
            >
              ${item.price}
            </span>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>
