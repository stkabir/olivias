---
const WA_BASE = "https://wa.me/522282557773?text=";

function pedirLink(item: string) {
  return WA_BASE + encodeURIComponent(`Hola Las Olivias, quisiera pedir: ${item} 🌮`);
}

const antojitos = [
  {
    name: "Picada Chica",
    desc: "Masa suave y esponjosa con frijoles cremosos, bañada en salsa roja o verde",
    price: 12,
  },
  {
    name: "Picada Grande Sencilla",
    desc: "Masa generosa y esponjosa, untada de frijoles y salsa de la casa",
    price: 42,
  },
  {
    name: "Picada Grande Preparada",
    desc: "La sencilla más tu relleno favorito: milanesa, pollo, papa o queso — la estrella del local",
    price: 50,
  },
  {
    name: "Empanada Chica",
    desc: "Masa crujiente recién hecha, rellena de queso, pollo, papa o picadillo",
    price: 12,
  },
  {
    name: "Empanada Gigante",
    desc: "Grande y generosa, crocante por fuera y suave por dentro — para los que tienen hambre de verdad",
    price: 42,
  },
  {
    name: "Tostada",
    desc: "Tortilla dorada y crujiente con frijoles untados y salsa de la casa",
    price: 20,
  },
  {
    name: "Dorado de Papa",
    desc: "Crocante y dorado por fuera, suave y bien sazonado por dentro",
    price: 12,
  },
  {
    name: "Tapaditas de Frijol",
    desc: "Pequeñas y adictivas, con frijol negro cremoso recién hecho",
    price: 12,
  },
  {
    name: "Taco de Guisado",
    desc: "Guiso del día, generoso y calientito envuelto en doble tortilla de maíz",
    price: 25,
  },
];

const platillos = [
  {
    name: "Huevos al Gusto",
    desc: "Recién hechos a tu estilo — jamón, longaniza, mexicana, rancheros, divorciados u omelet — con frijoles",
    price: 60,
  },
  {
    name: "Molletes",
    desc: "Telera dorada con frijoles cremosos y queso gratinado que se derrite: crujiente por fuera, fundente por dentro",
    price: 66,
  },
  {
    name: "Chilaquiles",
    desc: "Totopos crujientes bañados en salsa verde o roja, con pollo tierno, crema espesa y queso",
    price: 66,
  },
  {
    name: "Enfrijoladas",
    desc: "Tortillas suaves sumergidas en salsa de frijol negro, rellenas de pollo, queso, papa o huevo",
    price: 66,
  },
  {
    name: "Enmoladas",
    desc: "Bañadas en mole negro aromático y profundo — sabor tradicional veracruzano a cada bocado",
    price: 66,
  },
  {
    name: "Enchiladas",
    desc: "Tortillas rellenas y bañadas en salsa vibrante verde o roja, con crema y queso encima",
    price: 66,
  },
  {
    name: "Enchiladas Suizas",
    desc: "Las mismas enchiladas, pero gratinadas con queso fundido y crema — irresistibles",
    price: 87,
  },
  {
    name: "Milanesa",
    desc: "Empanizada, dorada y crujiente, acompañada de ensalada fresca, frijoles y arroz",
    price: 82,
  },
  {
    name: "Pechuga a la Plancha",
    desc: "Pechuga jugosa y bien sazonada, con ensalada fresca, frijoles y arroz",
    price: 82,
  },
];

const especialidades = [
  {
    name: "Pozole Chico",
    desc: "Caldo reconfortante de maíz y carne — solo los sábados, ¡no te lo pierdas!",
    price: 72,
  },
  {
    name: "Pozole Grande",
    desc: "Porción generosa del pozole más querido de Xalapa, con tostadas y guarniciones",
    price: 82,
  },
  {
    name: "Costilla de Cerdo",
    desc: "Suave y jugosa, bañada en salsa, acompañada de arroz y frijoles",
    price: 82,
  },
  {
    name: "Pollo con Mole",
    desc: "Pollo tierno bañado en mole negro profundo y aromático — sabor que abraza el alma",
    price: 77,
  },
];
---

<section id="menu" class="px-4 py-20 sm:px-6 sm:py-24">
  <div class="mx-auto max-w-5xl">

    <!-- Section header -->
    <div class="mb-12 flex flex-col items-center text-center">
      <span
        class="mb-3 inline-block rounded-full bg-clay-accent/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-clay-accent"
      >Nuestro Menú</span>
      <h2
        class="text-3xl font-black text-clay-text sm:text-4xl md:text-5xl"
        style="font-family: 'Nunito', sans-serif;"
      >
        <span class="clay-gradient-text">Hecho con amor,</span><br />servido con sabor
      </h2>
      <p class="mt-3 max-w-sm text-base font-medium text-clay-muted">
        Toca cualquier platillo para pedirlo directo por WhatsApp 💬
      </p>
    </div>

    <!-- ─── ANTOJITOS ─────────────────────────── -->
    <div class="mb-10">
      <div class="mb-5 flex items-center gap-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-2xl bg-linear-to-br from-amber-400 to-orange-500 text-xl"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        >🫓</span>
        <h3
          class="text-2xl font-black text-clay-text"
          style="font-family: 'Nunito', sans-serif;"
        >Antojitos</h3>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {antojitos.map((item) => (
          <a
            href={pedirLink(item.name)}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-start justify-between gap-3 rounded-4xl bg-amber-50/85 px-5 py-5 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
            style="box-shadow: var(--shadow-clay-card);"
          >
            <div class="flex flex-col gap-0.5 min-w-0">
              <span
                class="text-base font-extrabold text-clay-text transition-colors group-hover:text-amber-700"
                style="font-family: 'Nunito', sans-serif;"
              >{item.name}</span>
              <span class="text-sm font-medium leading-snug text-clay-muted">{item.desc}</span>
            </div>
            <span
              class="mt-0.5 shrink-0 rounded-full bg-linear-to-br from-amber-400 to-orange-500 px-3 py-1.5 text-sm font-black text-white"
              style="font-family: 'Nunito', sans-serif; box-shadow: 4px 4px 8px rgba(194,65,12,0.25);"
            >
              ${item.price}
            </span>
          </a>
        ))}
      </div>

      <!-- Extras note -->
      <div
        class="mt-4 flex items-start gap-3 rounded-3xl bg-amber-50/80 px-5 py-4"
        style="box-shadow: var(--shadow-clay-pressed);"
      >
        <span class="text-base" aria-hidden="true">ℹ️</span>
        <p class="text-xs font-medium text-clay-muted">
          <strong class="text-clay-text">Ingrediente extra:</strong> antojitos pequeños +$5 · antojitos gigantes +$10 ·
          <strong class="text-clay-text">Para llevar:</strong> +$6 por uso de desechable.
        </p>
      </div>
    </div>

    <!-- ─── PLATILLOS ─────────────────────────── -->
    <div class="mb-10">
      <div class="mb-5 flex items-center gap-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-2xl bg-linear-to-br from-clay-accent to-pink-700 text-xl"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        >🍳</span>
        <h3
          class="text-2xl font-black text-clay-text"
          style="font-family: 'Nunito', sans-serif;"
        >Platillos</h3>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {platillos.map((item) => (
          <a
            href={pedirLink(item.name)}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-start justify-between gap-3 rounded-4xl bg-rose-50/85 px-5 py-5 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
            style="box-shadow: var(--shadow-clay-card);"
          >
            <div class="flex flex-col gap-0.5 min-w-0">
              <span
                class="text-base font-extrabold text-clay-text transition-colors group-hover:text-clay-accent"
                style="font-family: 'Nunito', sans-serif;"
              >{item.name}</span>
              <span class="text-sm font-medium leading-snug text-clay-muted">{item.desc}</span>
            </div>
            <span
              class="mt-0.5 shrink-0 rounded-full bg-linear-to-br from-rose-500 to-pink-600 px-3 py-1.5 text-sm font-black text-white"
              style="font-family: 'Nunito', sans-serif; box-shadow: 4px 4px 8px rgba(219,39,119,0.25);"
            >
              ${item.price}
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- ─── ESPECIALIDADES (Solo Sábado) ─────── -->
    <div>
      <div class="mb-5 flex flex-wrap items-center gap-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-2xl bg-linear-to-br from-orange-500 to-red-600 text-xl"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        >🫕</span>
        <h3
          class="text-2xl font-black text-clay-text"
          style="font-family: 'Nunito', sans-serif;"
        >Especialidades</h3>
        <span
          class="inline-flex items-center gap-1 rounded-full bg-orange-100 px-3 py-1 text-xs font-bold text-orange-600"
        >
          📅 Solo Sábados
        </span>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {especialidades.map((item) => (
          <a
            href={pedirLink(item.name)}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-start justify-between gap-3 rounded-4xl bg-orange-50/85 px-5 py-5 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
            style="box-shadow: var(--shadow-clay-card);"
          >
            <div class="flex flex-col gap-0.5 min-w-0">
              <span
                class="text-base font-extrabold text-clay-text transition-colors group-hover:text-orange-700"
                style="font-family: 'Nunito', sans-serif;"
              >{item.name}</span>
              <span class="text-sm font-medium leading-snug text-clay-muted">{item.desc}</span>
            </div>
            <span
              class="mt-0.5 shrink-0 rounded-full bg-linear-to-br from-orange-500 to-red-600 px-3 py-1.5 text-sm font-black text-white"
              style="font-family: 'Nunito', sans-serif; box-shadow: 4px 4px 8px rgba(194,65,12,0.25);"
            >
              ${item.price}
            </span>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>
