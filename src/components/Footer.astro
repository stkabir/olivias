---
const year = new Date().getFullYear();
const WA_LINK = "https://wa.me/522282557773?text=Hola%20Las%20Olivias%2C%20quisiera%20hacer%20un%20pedido%20%F0%9F%8C%AE";
---

<footer class="px-4 pb-8 pt-4 sm:px-6">
  <div class="mx-auto max-w-5xl">
    <div
      class="flex flex-col items-center justify-between gap-5 rounded-4xl bg-white/65 px-6 py-5 backdrop-blur-xl sm:flex-row sm:px-8"
      style="box-shadow: var(--shadow-clay-nav);"
    >
      <!-- Logo -->
      <a
        href="#"
        class="flex items-center gap-2.5 no-underline"
        style="font-family: 'Nunito', sans-serif;"
        aria-label="Las Olivias — inicio"
      >
        <span
          class="flex h-8 w-8 items-center justify-center rounded-xl bg-linear-to-br from-pink-400 to-pink-600 text-sm font-black text-white"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        >O</span>
        <span class="text-sm font-black tracking-tight text-clay-text">
          Las <span class="text-clay-accent">Olivias</span>
        </span>
      </a>

      <!-- Address -->
      <p class="text-xs font-medium text-clay-muted text-center">
        Av 20 de Noviembre #323, Xalapa, Ver. · 228 255 7773
      </p>

      <!-- WhatsApp link -->
      <a
        href={WA_LINK}
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs font-bold text-clay-wa transition-colors hover:text-emerald-700"
      >
        Pedir por WhatsApp →
      </a>
    </div>

    <p class="mt-3 text-center text-xs font-medium text-clay-muted/60">
      © {year} Las Olivias · Tradición y sabor del pueblo
    </p>
  </div>
</footer>
