---
const WA_LINK = "https://wa.me/522282557773?text=Hola%20Las%20Olivias%2C%20quisiera%20hacer%20un%20pedido%20%F0%9F%8C%AE";
---

<section class="relative px-4 pb-16 pt-10 sm:px-6 sm:pt-14 md:pt-20">
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col items-center text-center">

      <!-- Badge — apetitoso y sensorial -->
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full bg-white/80 px-5 py-2 text-sm font-bold text-clay-muted backdrop-blur-md"
        style="box-shadow: var(--shadow-clay-card);"
      >
        <span class="animate-clay-breathe">🔥</span>
        <span>Antojitos frescos · Recién salido de la cocina</span>
      </div>

      <!-- Headline -->
      <h1
        class="max-w-3xl text-5xl font-black leading-[1.08] tracking-tight text-clay-text sm:text-6xl md:text-7xl lg:text-8xl"
        style="font-family: 'Nunito', sans-serif;"
      >
        Tradición y<br />
        <span class="clay-gradient-text">Sabor del Pueblo</span>
      </h1>

      <!-- Subheadline — sensorial, evoca hambre -->
      <p class="mx-auto mt-6 max-w-lg text-base font-medium leading-relaxed text-clay-muted sm:text-lg">
        Picadas calientitas, tortillas recién hechas y salsas de la casa — listos para atenderte desde las 8am en Xalapa.
      </p>

      <!-- Address pill -->
      <a
        href="https://maps.google.com/?q=Av+20+de+Noviembre+323+Xalapa+Veracruz"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center gap-2 rounded-full bg-white/70 px-4 py-2 text-sm font-medium text-clay-muted backdrop-blur-sm transition-all hover:text-clay-accent"
        style="box-shadow: var(--shadow-clay-nav);"
      >
        <span aria-hidden="true">📍</span>
        Av 20 de Noviembre #323, Xalapa Ver.
        <span class="text-clay-accent text-xs font-bold">Ver mapa →</span>
      </a>

      <!-- Primary CTA — WhatsApp -->
      <div class="mt-8 flex w-full flex-col items-center gap-4 sm:w-auto sm:flex-row sm:gap-4">
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-16 w-full items-center justify-center gap-3 rounded-3xl px-8 text-lg font-black tracking-wide text-white transition-all duration-200 hover:-translate-y-1 active:scale-[0.92] sm:w-auto"
          style="background: linear-gradient(135deg, #25D366, #128C7E); box-shadow: var(--shadow-clay-wa);"
        >
          <!-- WhatsApp icon -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Pedir por WhatsApp
        </a>
        <a
          href="#menu"
          class="inline-flex h-16 w-full items-center justify-center gap-2 rounded-3xl border-2 border-clay-accent/25 bg-transparent px-8 text-base font-bold text-clay-accent transition-all duration-200 hover:border-clay-accent hover:bg-clay-accent/5 hover:-translate-y-1 sm:w-auto"
        >
          Ver el Menú ↓
        </a>
      </div>

      <!-- Trust strip -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-5 text-sm text-clay-muted">
        <div class="flex items-center gap-1.5">
          <span class="text-clay-tertiary">★★★★★</span>
          <span class="font-bold text-clay-text">4.9</span>
          <span>en Facebook</span>
        </div>
        <div class="hidden h-4 w-px bg-clay-muted/20 sm:block"></div>
        <a href="tel:+522282557773" class="transition-colors hover:text-clay-accent">📞 228 255 7773</a>
        <div class="hidden h-4 w-px bg-clay-muted/20 sm:block"></div>
        <span>🕐 Lun–Sáb, 8am–6pm</span>
      </div>

    </div>

    <!-- Hero visual — mosaico fotográfico de platillos -->
    <div class="relative mx-auto mt-14 max-w-2xl">
      <div
        class="relative overflow-hidden rounded-6xl bg-white/50 p-4 backdrop-blur-xl sm:p-5"
        style="box-shadow: var(--shadow-clay-deep);"
      >
        <p
          class="mb-4 text-center text-sm font-black uppercase tracking-widest text-clay-muted"
          style="font-family: 'Nunito', sans-serif;"
        >
          ¿Qué se te antoja hoy?
        </p>
        <div class="grid grid-cols-2 gap-3">
          {[
            {
              img:   "https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=480&h=320&fit=crop&auto=format&q=80",
              label: "Picadas",
              color: "from-amber-900/65 to-orange-900/40",
            },
            {
              img:   "https://images.unsplash.com/photo-1529042410759-befb1204b468?w=480&h=320&fit=crop&auto=format&q=80",
              label: "Empanadas",
              color: "from-pink-900/65 to-rose-900/40",
            },
            {
              img:   "https://images.unsplash.com/photo-1599974579688-8dbdd335c77f?w=480&h=320&fit=crop&auto=format&q=80",
              label: "Platillos",
              color: "from-violet-900/65 to-purple-900/40",
            },
            {
              img:   "https://images.unsplash.com/photo-1547592180-85f173990554?w=480&h=320&fit=crop&auto=format&q=80",
              label: "Especialidades",
              color: "from-sky-900/65 to-cyan-900/40",
            },
          ].map((item) => (
            <a
              href="#menu"
              class="group relative overflow-hidden rounded-3xl transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02]"
              style="box-shadow: var(--shadow-clay-card); aspect-ratio: 4/3;"
            >
              <img
                src={item.img}
                alt={item.label}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <div class={`absolute inset-0 bg-linear-to-t ${item.color}`}></div>
              <div class="absolute bottom-0 left-0 right-0 p-3">
                <span
                  class="text-sm font-black text-white"
                  style="font-family: 'Nunito', sans-serif; text-shadow: 0 1px 4px rgba(0,0,0,0.6);"
                >{item.label}</span>
              </div>
            </a>
          ))}
        </div>

        <!-- Floating orbs desktop only -->
        <div
          class="absolute -right-5 -top-5 hidden h-16 w-16 rounded-full bg-linear-to-br from-amber-300 to-orange-400 lg:block animate-clay-float"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        ></div>
        <div
          class="absolute -bottom-4 -left-4 hidden h-12 w-12 rounded-full bg-linear-to-br from-pink-300 to-pink-500 lg:block animate-clay-float-delayed animation-delay-2000"
          style="box-shadow: var(--shadow-clay-button);"
          aria-hidden="true"
        ></div>
      </div>
    </div>

  </div>
</section>
