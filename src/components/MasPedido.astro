---
// Los 4 platillos más pedidos — con descripciones sensoriales y CTA directo a WhatsApp

const WA_BASE = "https://wa.me/522282557773?text=";

function pedirLink(item: string) {
  return WA_BASE + encodeURIComponent(`Hola Las Olivias, quisiera pedir: ${item} 🌮`);
}

const estrellas = [
  {
    img:    "https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=600&h=280&fit=crop&auto=format&q=80",
    nombre: "Picada Grande Preparada",
    desc:   "Masa suave y esponjosa, frijoles cremosos de la casa, salsa roja o verde — y tu relleno favorito encima. El antojito que más piden.",
    precio: 50,
    color:  { from: "#F59E0B", to: "#EA580C" },
    badge:  "El más pedido",
  },
  {
    img:    "https://images.unsplash.com/photo-1582878826629-29b7ad1cdc43?w=600&h=280&fit=crop&auto=format&q=80",
    nombre: "Chilaquiles",
    desc:   "Totopos crujientes bañados en salsa verde o roja, con pollo tierno desmenuzado, crema espesa y queso desmoronado. El desayuno que enamora.",
    precio: 66,
    color:  { from: "#16A34A", to: "#15803D" },
    badge:  "Favorito del desayuno",
  },
  {
    img:    "https://images.unsplash.com/photo-1599974579688-8dbdd335c77f?w=600&h=280&fit=crop&auto=format&q=80",
    nombre: "Taco de Guisado",
    desc:   "El guiso del día en doble tortilla de maíz recién hecha, calientito y generoso. Sencillo, honesto y delicioso.",
    precio: 25,
    color:  { from: "#DB2777", to: "#9D174D" },
    badge:  "Clásico del local",
  },
  {
    img:    "https://images.unsplash.com/photo-1574484284002-952d92456975?w=600&h=280&fit=crop&auto=format&q=80",
    nombre: "Enchiladas",
    desc:   "Tortillas rellenas de pollo, papa, queso o huevo, bañadas en salsa verde o roja con crema. Reconfortantes y llenas de sabor.",
    precio: 66,
    color:  { from: "#7C3AED", to: "#5B21B6" },
    badge:  "Para compartir",
  },
];
---

<section class="px-4 pb-4 pt-16 sm:px-6 sm:pt-20">
  <div class="mx-auto max-w-5xl">

    <!-- Header -->
    <div class="mb-10 flex flex-col items-center text-center">
      <div class="mb-3 flex items-center gap-2">
        <span class="text-2xl animate-clay-breathe" aria-hidden="true">🔥</span>
        <span
          class="inline-block rounded-full bg-orange-100 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-orange-600"
        >Lo Más Pedido</span>
      </div>
      <h2
        class="text-3xl font-black text-clay-text sm:text-4xl md:text-5xl"
        style="font-family: 'Nunito', sans-serif;"
      >
        Los favoritos que<br />
        <span class="clay-gradient-text">no pueden faltar</span>
      </h2>
      <p class="mt-3 max-w-sm text-sm font-medium text-clay-muted">
        Un toque y tu antojo llega por WhatsApp. Así de fácil.
      </p>
    </div>

    <!-- Grid de 4 tarjetas — 2 col desktop, 1 col mobile -->
    <div class="grid gap-5 sm:grid-cols-2">
      {estrellas.map((p) => (
        <article
          class="group relative flex flex-col overflow-hidden rounded-4xl bg-amber-50/90 backdrop-blur-xl transition-all duration-300 hover:-translate-y-2"
          style="box-shadow: var(--shadow-clay-card);"
        >
          <!-- Header — foto real del platillo -->
          <div class="relative overflow-hidden" style="height: 180px;">
            <img
              src={p.img}
              alt={p.nombre}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Overlay de color de la marca -->
            <div
              class="absolute inset-0"
              style={`background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 55%), linear-gradient(135deg, ${p.color.from}55, transparent 70%);`}
            ></div>
            <!-- Precio en esquina superior derecha -->
            <span
              class="absolute right-4 top-4 rounded-2xl bg-black/30 px-4 py-2 text-xl font-black text-white backdrop-blur-sm"
              style="font-family: 'Nunito', sans-serif;"
            >
              ${p.precio}
            </span>
          </div>

          <!-- Contenido -->
          <div class="flex flex-1 flex-col gap-3 p-6">
            <!-- Badge + Nombre -->
            <div>
              <span
                class="mb-1.5 inline-block rounded-full bg-orange-50 px-2.5 py-0.5 text-xs font-bold text-orange-600"
              >⭐ {p.badge}</span>
              <h3
                class="text-xl font-extrabold text-clay-text"
                style="font-family: 'Nunito', sans-serif;"
              >{p.nombre}</h3>
            </div>

            <!-- Descripción sensorial -->
            <p class="text-sm font-medium leading-relaxed text-clay-muted">
              {p.desc}
            </p>

            <!-- CTA WhatsApp -->
            <a
              href={pedirLink(p.nombre)}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-auto inline-flex h-14 w-full items-center justify-center gap-2 rounded-3xl text-base font-black tracking-wide text-white transition-all duration-200 hover:-translate-y-0.5 active:scale-[0.92]"
              style={`background: linear-gradient(135deg, ${p.color.from}, ${p.color.to}); box-shadow: var(--shadow-clay-button);`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Pedir este platillo
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Link al menú completo -->
    <div class="mt-8 flex justify-center">
      <a
        href="#menu"
        class="inline-flex items-center gap-2 rounded-full bg-white/70 px-6 py-3 text-sm font-bold text-clay-muted backdrop-blur-md transition-all hover:-translate-y-0.5 hover:text-clay-accent"
        style="box-shadow: var(--shadow-clay-nav);"
      >
        Ver el menú completo ↓
      </a>
    </div>

  </div>
</section>
